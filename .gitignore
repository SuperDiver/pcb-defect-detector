# === 训练产物（可重新生成，体积大） ===
runs/

# === 数据集（10,000+ 张图，几百 MB，不能 push） ===
data/PCB Defects.v6i.yolov8/train/
data/PCB Defects.v6i.yolov8/valid/
data/PCB Defects.v6i.yolov8/test/
data/pre_test/

# === 保留 data.yaml 和示例图片 ===
!data/PCB Defects.v6i.yolov8/data.yaml
!data/sample_images/
!data/sample_results/

# === 模型权重（可重新训练/下载，22MB 也偏大） ===
# 可以把 best.pt 留作 release 附件而不是 git 跟踪
*.pt
*.onnx
*.engine
!weights/best.pt
!weights/best.onnx

# === Python 缓存 ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# === IDE ===
.vscode/
.idea/

# === 虚拟环境 ===
.venv/
venv/
env/

# === 系统文件 ===
.DS_Store
Thumbs.db

# === Gradio 运行时缓存 ===
gradio/
gradio_certs/
certificate.pem
*.pem